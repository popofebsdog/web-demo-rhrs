{
  "graph_說明": "RHRS易致災因果知識圖譜。nodes為實體，edges為帶語意關係。relation類型：contains(層級包含)、triggers(觸發×)、amplifies(放大→)、mitigates(折減÷)、measured_by(由表單欄位量測)、sourced_from(來源表單)。",
  "風險公式": "殘餘風險 = (A 潛勢 × B 觸發) × C 後果暴露 ÷ D 防護",
  "nodes": [
    { "id": "RISK", "label": "殘餘風險", "type": "outcome" },
    { "id": "EVENT", "label": "邊坡失穩事件", "type": "event" },

    { "id": "A", "label": "邊坡本體潛勢條件", "type": "factor_group", "role": "潛勢(內在條件)", "對應": "脆弱度" },
    { "id": "B", "label": "氣象誘發因子", "type": "factor_group", "role": "觸發(外在扳機)", "對應": "觸發條件" },
    { "id": "C", "label": "歷史規模與交通暴露", "type": "factor_group", "role": "後果(放大器)", "對應": "發生率×暴露度" },
    { "id": "D", "label": "現有防護設施加權", "type": "factor_group", "role": "折減(負回饋)", "對應": "風險折減" },

    { "id": "A1", "label": "地形特徵", "type": "factor", "取值法": "取平均" },
    { "id": "A2", "label": "地質狀況", "type": "factor", "取值法": "取大值" },
    { "id": "A3", "label": "邊坡植被及水流狀況", "type": "factor", "取值法": "取大值" },
    { "id": "B1", "label": "氣象加權", "type": "factor", "取值法": "加權係數" },
    { "id": "C1", "label": "近三年落石坍方歷史", "type": "factor", "取值法": "取大值" },
    { "id": "C2", "label": "落石尺寸坍方規模", "type": "factor", "取值法": "取大值" },
    { "id": "C3", "label": "交通流量狀況", "type": "factor" },
    { "id": "C4", "label": "道路寬度及墾地有無", "type": "factor", "取值法": "取平均" },
    { "id": "C5", "label": "區域聯外交通影響", "type": "factor" },
    { "id": "D1", "label": "防護設施成效", "type": "factor", "取值法": "加權係數" },

    { "id": "F_A31", "label": "表A3-1 自然邊坡特別檢測表", "type": "form" },
    { "id": "F_A34", "label": "表A3-4 噴凝土護坡設施檢測表", "type": "form" },
    { "id": "F_A35", "label": "表A3-5 混凝土格框格子梁護坡檢測表", "type": "form" },
    { "id": "F_A310", "label": "表A3-10 圖片說明表", "type": "form" },

    { "id": "FLD_地質類型", "label": "地質類型(土/岩/礫石)", "type": "field" },
    { "id": "FLD_坡高", "label": "坡高", "type": "field" },
    { "id": "FLD_坡度", "label": "坡度", "type": "field" },
    { "id": "FLD_邊坡面寬", "label": "邊坡面寬", "type": "field" },
    { "id": "FLD_坡型", "label": "坡型", "type": "field" },
    { "id": "FLD_岩性", "label": "岩性/不連續面/順逆向", "type": "field" },
    { "id": "FLD_植被覆蓋", "label": "植被覆蓋率", "type": "field" },
    { "id": "FLD_地下水", "label": "地下水/湧水狀況", "type": "field" },
    { "id": "FLD_排洩水管", "label": "排洩水管(正常/阻塞)", "type": "field" },
    { "id": "FLD_天氣", "label": "天氣/坡面乾濕", "type": "field" },
    { "id": "FLD_降雨", "label": "降雨量/降雨後日數", "type": "field" },
    { "id": "FLD_以往災害", "label": "以往災害(無/有)", "type": "field" },
    { "id": "FLD_鄰近災害", "label": "鄰近災害(無/有)", "type": "field" },
    { "id": "FLD_崩落物料", "label": "潛在崩落物料/落石尺寸", "type": "field" },
    { "id": "FLD_交通量", "label": "日平均交通量PCU/車種", "type": "field" },
    { "id": "FLD_道路寬度", "label": "道路寬度/墾地/應變視距", "type": "field" },
    { "id": "FLD_聯外", "label": "聯外道路/替代道路", "type": "field" },
    { "id": "FLD_監測系統", "label": "監測系統/監測情形", "type": "field" },
    { "id": "FLD_設施檢查", "label": "設施檢查項目(A3-1/4/5)", "type": "field" },
    { "id": "FLD_圖片", "label": "現場記錄圖片", "type": "field" }
  ],
  "edges": [
    { "from": "A", "to": "EVENT", "relation": "triggers", "operator": "×", "note": "A潛勢與B觸發須同時成立才失穩" },
    { "from": "B", "to": "EVENT", "relation": "triggers", "operator": "×", "note": "豪雨扣下扳機，把A潛能轉為運動" },
    { "from": "EVENT", "to": "C", "relation": "amplifies", "operator": "→", "note": "事件發生後由C決定後果規模" },
    { "from": "C", "to": "RISK", "relation": "amplifies", "operator": "×" },
    { "from": "D", "to": "RISK", "relation": "mitigates", "operator": "÷", "note": "防護工程折減殘餘風險，不改變A地質本體" },

    { "from": "A", "to": "A1", "relation": "contains" },
    { "from": "A", "to": "A2", "relation": "contains" },
    { "from": "A", "to": "A3", "relation": "contains" },
    { "from": "B", "to": "B1", "relation": "contains" },
    { "from": "C", "to": "C1", "relation": "contains" },
    { "from": "C", "to": "C2", "relation": "contains" },
    { "from": "C", "to": "C3", "relation": "contains" },
    { "from": "C", "to": "C4", "relation": "contains" },
    { "from": "C", "to": "C5", "relation": "contains" },
    { "from": "D", "to": "D1", "relation": "contains" },

    { "from": "A1", "to": "FLD_地質類型", "relation": "measured_by" },
    { "from": "A1", "to": "FLD_坡高", "relation": "measured_by" },
    { "from": "A1", "to": "FLD_坡度", "relation": "measured_by" },
    { "from": "A1", "to": "FLD_邊坡面寬", "relation": "measured_by" },
    { "from": "A1", "to": "FLD_坡型", "relation": "measured_by" },
    { "from": "A2", "to": "FLD_岩性", "relation": "measured_by" },
    { "from": "A3", "to": "FLD_植被覆蓋", "relation": "measured_by" },
    { "from": "A3", "to": "FLD_地下水", "relation": "measured_by" },
    { "from": "A3", "to": "FLD_排洩水管", "relation": "measured_by" },
    { "from": "B1", "to": "FLD_天氣", "relation": "measured_by" },
    { "from": "B1", "to": "FLD_降雨", "relation": "measured_by" },
    { "from": "C1", "to": "FLD_以往災害", "relation": "measured_by" },
    { "from": "C1", "to": "FLD_鄰近災害", "relation": "measured_by" },
    { "from": "C2", "to": "FLD_崩落物料", "relation": "measured_by" },
    { "from": "C3", "to": "FLD_交通量", "relation": "measured_by" },
    { "from": "C4", "to": "FLD_道路寬度", "relation": "measured_by" },
    { "from": "C5", "to": "FLD_聯外", "relation": "measured_by" },
    { "from": "D1", "to": "FLD_監測系統", "relation": "measured_by" },
    { "from": "D1", "to": "FLD_設施檢查", "relation": "measured_by" },
    { "from": "D1", "to": "FLD_圖片", "relation": "measured_by" },

    { "from": "FLD_地質類型", "to": "F_A31", "relation": "sourced_from" },
    { "from": "FLD_坡高", "to": "F_A31", "relation": "sourced_from" },
    { "from": "FLD_以往災害", "to": "F_A31", "relation": "sourced_from" },
    { "from": "FLD_設施檢查", "to": "F_A34", "relation": "sourced_from" },
    { "from": "FLD_設施檢查", "to": "F_A35", "relation": "sourced_from" },
    { "from": "FLD_崩落物料", "to": "F_A310", "relation": "sourced_from" },
    { "from": "FLD_圖片", "to": "F_A310", "relation": "sourced_from" }
  ]
}
