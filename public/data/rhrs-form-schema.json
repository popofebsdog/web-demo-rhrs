{
  "schema_說明": "以RHRS易致災評估因子(A/B/C/D)為因果分層骨架，對應四張現場檢測表單之所有欄位。value一律留空，供填寫；options列出表單可勾選項。",
  "風險公式": "風險 = 發生率(危害度) × 潛勢能(脆弱度) × 暴露度 （再以 D 防護設施折減）",
  "因果關係": {
    "因果鏈": "A(內在弱點) 被 B(豪雨)觸發 → 產生失穩 → C(歷史/規模/交通)決定後果大小 → D(防護工程)折減後得殘餘風險",
    "運算式": "殘餘風險 = (A 潛勢 × B 觸發) × C 後果暴露 ÷ D 防護",
    "非線性說明": "非單純 A→B→C→D 線性相接；A 與 B 為相乘(同時成立才觸發)，D 為反向折減。",
    "各層角色": {
      "A_潛勢": "內在條件/必要條件：邊坡先天弱點，靜態脆弱度，本身不會自崩。",
      "B_觸發": "外在扳機：豪雨等外力，把 A 的潛能轉為實際運動。A 與 B 須同時成立(A×B)。",
      "C_後果": "結果放大器：事件發生後決定嚴重程度(發生率×暴露度)。",
      "D_折減": "負回饋：人為防護攔截 A×B 之結果、降低 C 衝擊，不改變地質本體。"
    }
  },
